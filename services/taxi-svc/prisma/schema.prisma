// ===================================================
// SenimdiQAdam — taxi-svc Prisma Schema
// ===================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ──────────────────────────────────────────────────────────────────

enum DriverStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum BookingStatus {
  PENDING       // ждёт рассмотрения менеджером
  CONFIRMED     // менеджер назначил водителя
  IN_PROGRESS   // поездка идёт
  COMPLETED     // завершена
  CANCELLED     // отменена
}

enum VehicleType {
  SEDAN
  MINIVAN
  WHEELCHAIR_VAN
  OTHER
}

enum DisabilityType {
  WHEELCHAIR    // инвалидная коляска
  VISUAL        // нарушение зрения
  HEARING       // нарушение слуха
  MOBILITY      // нарушение опорно-двигательного аппарата
  OTHER
}

enum MessageSender {
  USER
  MANAGER
}

// ── Models ─────────────────────────────────────────────────────────────────

// Менеджеры такси (регистрируются через инвайт-код)
model TaxiManager {
  id        String   @id @default(uuid())
  userId    String   @unique  // ссылка на User в core-svc
  firstName String
  lastName  String
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  bookings  Booking[]        // заявки которые вёл этот менеджер
  messages  BookingMessage[]

  @@index([userId])
}

// Водители
model Driver {
  id           String       @id @default(uuid())
  userId       String?      @unique  // в будущем — свой аккаунт
  firstName    String
  lastName     String
  phone        String       @unique
  whatsapp     String?      // номер для WA (может отличаться)
  vehicleType  VehicleType  @default(WHEELCHAIR_VAN)
  vehicleModel String?
  licensePlate String       @unique
  status       DriverStatus @default(ACTIVE)
  ratingAvg    Float        @default(0)
  ratingCount  Int          @default(0)
  totalTrips   Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  bookings Booking[]
  reviews  DriverReview[]

  @@index([status])
}

// Заявки на поездку
model Booking {
  id             String         @id @default(uuid())
  userId         String         // id из core-svc
  managerId      String?        // кто назначил
  manager        TaxiManager?   @relation(fields: [managerId], references: [id])
  driverId       String?        // назначается менеджером
  driver         Driver?        @relation(fields: [driverId], references: [id])

  // маршрут
  fromAddress    String
  toAddress      String
  fromLat        Float?
  fromLon        Float?
  toLat          Float?
  toLon          Float?

  // детали
  scheduledAt    DateTime       // желаемое время поездки
  disabilityType DisabilityType
  note           String?        // особые пожелания
  status         BookingStatus  @default(PENDING)
  cancelReason   String?        // причина отмены

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  messages BookingMessage[]
  review   DriverReview?

  // сортировка очереди по времени подачи
  @@index([status, createdAt])
  @@index([userId])
  @@index([driverId])
}

// Чат: пользователь ↔ менеджер (в рамках заявки)
model BookingMessage {
  id         String        @id @default(uuid())
  bookingId  String
  booking    Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  managerId  String?
  manager    TaxiManager?  @relation(fields: [managerId], references: [id])
  senderId   String        // userId из core-svc (кто отправил)
  senderType MessageSender // USER или MANAGER
  text       String
  isRead     Boolean       @default(false)
  createdAt  DateTime      @default(now())

  @@index([bookingId, createdAt])
}

// Отзывы на водителя (после COMPLETED поездки)
model DriverReview {
  id        String   @id @default(uuid())
  bookingId String   @unique  // один отзыв на поездку
  booking   Booking  @relation(fields: [bookingId], references: [id])
  driverId  String
  driver    Driver   @relation(fields: [driverId], references: [id])
  userId    String   // из core-svc
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())

  @@index([driverId])
}

// Инвайт-коды для регистрации менеджеров
model ManagerInvite {
  id        String   @id @default(uuid())
  code      String   @unique
  usedBy    String?  // userId кто использовал
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([code])
}
